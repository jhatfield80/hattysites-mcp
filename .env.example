# ============================================================
# Hatty.ai MCP Server - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ------------------------------------------------------------
# Anthropic (Claude Agent)
# Get from: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------
# Google Ads API
# Get developer token: https://developers.google.com/google-ads/api/docs/get-started/dev-token
# Create OAuth client: https://console.cloud.google.com/
# ------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token-here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# ------------------------------------------------------------
# Meta Marketing API
# Create app: https://developers.facebook.com/
# ------------------------------------------------------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ------------------------------------------------------------
# Email Delivery (SendGrid - optional)
# Get from: https://sendgrid.com/
# ------------------------------------------------------------
SENDGRID_API_KEY=SG.your-key-here
HATTY_FROM_EMAIL=reports@hattysites.com
HATTY_FROM_NAME=Hatty.ai Reports

# ------------------------------------------------------------
# MCP Server Settings
# ------------------------------------------------------------
HATTY_MCP_HOST=0.0.0.0
HATTY_MCP_PORT=8000
HATTY_MCP_URL=https://mcp.hattysites.com/mcp

# Path to client credentials directory (OAuth tokens)
HATTY_CREDENTIALS_DIR=./credentials

# Path to config files
HATTY_CONFIG_DIR=./config

# Path to skills directory
HATTY_SKILLS_DIR=./skills

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------
# SECURITY - do not change these defaults
# ------------------------------------------------------------
# Credentials are stored locally, never in the database
# OAuth tokens are auto-refreshed
# .env is gitignored
